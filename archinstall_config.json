{
  "app_config": {
    "audio_config": {
      "audio": "pipewire"
    },
    "bluetooth_config": {
      "enabled": true
    },
    "fonts_config": {
      "fonts": [
        "noto-fonts",
        "noto-fonts-emoji",
        "noto-fonts-cjk",
        "ttf-liberation",
        "ttf-dejavu"
      ]
    },
    "power_management_config": {
      "power_management": "power-profiles-daemon"
    },
    "print_service_config": {
      "enabled": true
    }
  },
  "archinstall-language": "English",
  "auth_config": {},
  "bootloader_config": {
    "bootloader": "Systemd-boot",
    "removable": false,
    "uki": true
  },
  "custom_commands": [
    "echo 'krsz ALL=(ALL) NOPASSWD: ALL' > /etc/sudoers.d/00_krsz",
    "echo 'XMODIFIERS=@im=fcitx' >> /etc/environment"
  ],
  "hostname": "krsz-arch",
  "kernels": ["linux"],
  "locale_config": {
    "kb_layout": "us",
    "sys_enc": "UTF-8",
    "sys_lang": "en_AU.UTF-8"
  },
  "mirror_config": {
    "custom_repositories": [],
    "custom_servers": [],
    "mirror_regions": {},
    "optional_repositories": ["multilib"]
  },
  "network_config": {
    "type": "nm"
  },
  "ntp": true,
  "packages": [
    "bind",
    "btop",
    "cloudflared",
    "dolphin",
    "fastfetch",
    "fcitx5",
    "fcitx5-chinese-addons",
    "fcitx5-gtk",
    "fcitx5-pinyin-zhwiki",
    "fcitx5-qt",
    "firefox",
    "git",
    "github-cli",
    "konsole",
    "libreoffice-still",
    "nodejs",
    "tigervnc",
    "uv",
    "zed",
    "yt-dlp"
  ],
  "pacman_config": {
    "color": true,
    "parallel_downloads": 5
  },
  "profile_config": {
    "gfx_driver": "All open-source",
    "greeter": "plasma-login-manager",
    "profile": {
      "custom_settings": {
        "KDE Plasma": {
          "plasma_flavor": "plasma-meta"
        }
      },
      "details": ["KDE Plasma"],
      "main": "Desktop"
    }
  },
  "script": null,
  "services": [],
  "swap": {
    "algorithm": "zstd",
    "enabled": true
  },
  "timezone": "Australia/Sydney",
  "version": "4.3"
}
